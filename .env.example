# Strava OAuth (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8721/callback

# LLM backend
#   api        — call api.anthropic.com directly (requires ANTHROPIC_API_KEY + credits)
#   claude_cli — shell out to `claude -p` (uses your Claude Max subscription
#                via CLAUDE_CODE_OAUTH_TOKEN; no API credits needed)
NAMR_BACKEND=api
NAMR_MODEL=claude-sonnet-4-6

# Required only when NAMR_BACKEND=api
ANTHROPIC_API_KEY=

# Required only when NAMR_BACKEND=claude_cli — get this from `claude setup-token`
# (Optional override if `claude` is not on PATH:)
# NAMR_CLAUDE_CLI_PATH=claude
# CLAUDE_CODE_OAUTH_TOKEN=

# State
NAMR_DB_PATH=data/namr.db

# Pipeline
NAMR_POLL_INTERVAL_SECONDS=86400
NAMR_LOOKBACK_HOURS=48
NAMR_PROCESS_DELAY_SECONDS=900
NAMR_SPORTS=Run,Ride,TrailRun,VirtualRun,VirtualRide
NAMR_SKIP_COMMUTE=true
NAMR_SKIP_RACE=true

# Kill switch — set to "true" to disable writes (logs would-rename instead)
NAMR_DRY_RUN=false
NAMR_DISABLED=false

# Append attribution to the activity description on rename
NAMR_APPEND_FOOTER=true
# NAMR_FOOTER="Title auto-generated by Claude via namr — https://github.com/jeiros/namr"

# Budget — hard cap on LLM generations per UTC day
NAMR_DAILY_LLM_CAP=50

# Optional context enrichers
NAMR_USE_GEOCODE=true
NAMR_USE_WEATHER=true
NAMR_GEOCODE_USER_AGENT=namr/0.1 (jeirosz@gmail.com)
